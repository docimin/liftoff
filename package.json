{
  "name": "liftoff",
  "version": "0.1.0",
  "description": "Migrate Docker Compose stacks between servers",
  "type": "module",
  "bin": {
    "liftoff": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "build": "bun build --compile src/index.ts --outfile liftoff",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "ssh2": "^1.17.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/ssh2": "^1.15.5"
  }
}
