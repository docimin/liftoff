{
  "name": "liftoff",
  "version": "0.1.0",
  "description": "Migrate Docker Compose stacks between servers with minimal downtime",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "test": "bun test",
    "build": "bun build --compile src/index.ts --outfile liftoff",
    "build:all": "bash scripts/build.sh",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "keywords": [
    "docker",
    "docker-compose",
    "migration",
    "server",
    "self-hosted",
    "devops",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/docimin/liftoff"
  },
  "homepage": "https://github.com/docimin/liftoff#readme",
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "ink": "^6.8.0",
    "react": "^19.2.4",
    "ssh2": "^1.17.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@types/react": "^19.2.14",
    "@types/ssh2": "^1.15.5"
  }
}
